    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Get inputs\nlet text = ($('Is Prompt error').item.json.followupMessage ?? \n           $('Is Prompt error').item.json.output?.followupMessage) || '';\n\ntext += \"/n/n\" + $('Call \\'Nudge Excel Config\\'').item.json.aiWarningText;\n\nlet tokens = $('Call \\'Redactor\\' body').item.json.tokenMap;\n\n// Ensure tokens is an object\nif (typeof tokens === 'string') {\n  try {\n    tokens = JSON.parse(tokens);\n  } catch (err) {\n    tokens = {};\n  }\n}\nif (!tokens || typeof tokens !== 'object') {\n  tokens = {};\n}\n\n// Escape regex special characters\nfunction escapeRegex(str) {\n  if (typeof str !== 'string') return '';\n  return str.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n}\n\n// Replace tokens safely\nfor (const key in tokens) {\n  // Skip invalid keys\n  if (typeof key !== 'string' || !key.trim()) continue;\n\n  const value = tokens[key];\n\n  // Skip invalid values\n  if (typeof value !== 'string') continue;\n\n  let replacement = value;\n\n  // URL handling (optional — here just passes through)\n  if (value.startsWith('http://') || value.startsWith('https://')) {\n    replacement = `<a href=\"${value}\">${value}</a>`;\n  }\n\n  const regex = new RegExp(escapeRegex(key), 'g');\n  text = text.replace(regex, replacement);\n}\n\n// Return result\nreturn {\n  storedMessage: text\n};\n"
      },
