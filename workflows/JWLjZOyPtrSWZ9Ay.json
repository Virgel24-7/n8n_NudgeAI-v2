      "id": "50cc84ba-d350-4b74-9685-8b7fb553e62f",
      "name": "Update nextfollowupsent",
      "credentials": {
        "microsoftExcelOAuth2Api": {
          "id": "3jmhUJAMJYXz5iHm",
          "name": "Microsoft Excel account"
