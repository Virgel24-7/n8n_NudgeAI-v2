    {
      "parameters": {
        "jsCode": "const inbox = $input.all();\nconst expectedRec = $('Get a message').first().json.toRecipients || [];\nconst convId = $('Update to processing').first().json.conversationId;\nconst sender = $('Update to processing').first().json.sender;\nconst agentEmail = $('Call \\'Nudge Config\\'').first().json.agentEmail;\n\n// Flatten expected recipients into an array of addresses\nconst expectedAddresses = expectedRec.map(r => r.emailAddress?.address).filter(Boolean);\n\nconst reply = inbox.find(m =>\n  m.json.conversationId === convId &&\n  m.json.sender?.emailAddress?.address !== sender &&\n  m.json.sender?.emailAddress?.address !== agentEmail && expectedAddresses.includes(m.json.sender?.emailAddress?.address)\n);\n\nreturn {\n  hasReply: !!reply\n};\n"
      },
