        "jsCode": "const toList = ($('Get a message').item.json.toRecipients).filter((val) => val.emailAddress.address != $('Call \\'Nudge Config\\'').first().json.agentEmail);\n\nconst ccClean = ($('Get a message').item.json.ccRecipients).filter((val) => val.emailAddress.address != $('Call \\'Nudge Config\\'').first().json.agentEmail);\n\nconst ccList = [$('Get a message').first().json.sender, ...ccClean];\n\nconst bccList = ($('Get a message').item.json.bccRecipients).filter((val) => val.emailAddress.address != $('Call \\'Nudge Config\\'').first().json.agentEmail);\n\nreturn {toList: toList, ccList: ccList, bccList: bccList};"
